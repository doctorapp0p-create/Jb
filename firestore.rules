rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- গ্লোবাল ডিফল্ট: সবকিছু বন্ধ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- হেল্পার ফাংশন ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // প্রোফাইল থেকে রোল চেক করা safely
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', '') == role;
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'doctorapp0p@gmail.com' || 
        request.auth.token.get('email', '') == 'moderator@nilpha.com'
      ); 
    }
    function isDoctor() { return hasRole('DOCTOR'); }
    
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    function isValidOrder(data) {
      return data.user_id == request.auth.uid &&
             data.item_name is string && data.item_name.size() <= 1000 &&
             data.amount is number &&
             data.sender_name is string && data.sender_name.size() <= 200 &&
             data.sender_contact is string && data.sender_contact.size() <= 20 &&
             (!('patient_name' in data) || (data.patient_name is string && data.patient_name.size() <= 200)) &&
             data.status == 'pending';
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- প্রোফাইল রুলস ---
    match /profiles/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && (
          (incoming().get('role', '') == 'PATIENT' && incoming().get('status', '') == 'active') ||
          (incoming().get('role', '') == 'RURAL_DOCTOR' && incoming().get('status', '') == 'active')
        )) ||
        isAdmin()
      );
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['full_name', 'phone']))
      );
    }

    // --- অ্যাপ সেটিংস ---
    match /settings/{settingId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- কানেকশন টেস্ট ---
    match /_connection_test_/{docId} {
      allow read: if true;
    }

    // --- ডাক্তার, হাসপাতাল এবং ল্যাব টেস্ট লিস্ট ---
    match /doctors/{doctorId} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /lab_tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- প্রেসক্রিপশন রুলস ---
    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.patient_id || 
        request.auth.uid == resource.data.doctor_id || 
        isAdmin()
      );
      allow create: if isDoctor() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // --- অর্ডার রুলস ---
    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && existing().user_id == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['sender_name', 'sender_contact', 'patient_name', 'trx_id', 'payment_method'])
      );
      allow delete: if isAdmin();
    }

    // --- অ্যাপয়েন্টমেন্ট রুলস ---
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && (existing().patient_id == request.auth.uid || isAdmin() || hasRole('RURAL_DOCTOR'));
      allow list: if isSignedIn() && (resource.data.patient_id == request.auth.uid || isAdmin() || hasRole('RURAL_DOCTOR'));
      allow create: if isSignedIn() && incoming().patient_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
