rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- গ্লোবাল ডিফল্ট: সবকিছু বন্ধ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- হেল্পার ফাংশন ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // প্রোফাইল থেকে রোল চেক করা (বড় হাতের অক্ষরে কোড অনুযায়ী)
    function getUserData() { 
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data; 
    }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'doctorapp0p@gmail.com' || 
        request.auth.token.email == 'moderator@nilpha.com' ||
        getUserData().role == 'ADMIN'
      ); 
    }
    function isDoctor() { return isSignedIn() && getUserData().role == 'DOCTOR'; }
    
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    function isValidOrder(data) {
      return data.user_id == request.auth.uid &&
             data.item_name is string && data.item_name.size() <= 1000 &&
             data.amount is number &&
             data.sender_name is string && data.sender_name.size() <= 200 &&
             data.sender_contact is string && data.sender_contact.size() <= 20 &&
             (!('patient_name' in data) || (data.patient_name is string && data.patient_name.size() <= 200)) &&
             data.status == 'pending';
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- প্রোফাইল রুলস ---
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && (
        (incoming().role == 'PATIENT' && incoming().status == 'active') ||
        (request.auth.token.email == 'moderator@nilpha.com' && incoming().role == 'ADMIN')
      );
      allow update: if isAdmin() || (
        isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['full_name', 'phone'])
      );
    }

    // --- অ্যাপ সেটিংস ---
    match /settings/{settingId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- কানেকশন টেস্ট ---
    match /_connection_test_/{docId} {
      allow read: if true;
    }

    // --- ডাক্তার, হাসপাতাল এবং ল্যাব টেস্ট লিস্ট ---
    match /doctors/{doctorId} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /lab_tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- প্রেসক্রিপশন রুলস ---
    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.patient_id || 
        request.auth.uid == resource.data.doctor_id || 
        isAdmin()
      );
      allow create: if isDoctor() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // --- অর্ডার রুলস ---
    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && existing().user_id == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['sender_name', 'sender_contact', 'patient_name', 'trx_id', 'payment_method'])
      );
      allow delete: if isAdmin();
    }
  }
}
